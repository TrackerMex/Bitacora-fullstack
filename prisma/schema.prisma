generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// TENANT MODEL - Multi-Tenancy Core
// ============================================
model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users           User[]
  roles           Role[]
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@index([slug])
  @@index([isActive])
  @@index([createdAt])
}

// ============================================
// USER MODEL - Isolated by Tenant
// ============================================
model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String
  name         String?
  passwordHash String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roles  UserRole[]

  // Indexes for performance
  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, createdAt])
}

// ============================================
// ROLE MODEL - Isolated by Tenant
// ============================================
model Role {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  key         String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       UserRole[]
  permissions RolePermission[]

  // Indexes for performance
  @@unique([tenantId, key])
  @@index([tenantId])
  @@index([tenantId, isActive])
}

// ============================================
// PERMISSION MODEL - Global (Shared across tenants)
// ============================================
model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  key         String   @unique
  module      String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  roles RolePermission[]

  @@index([module])
  @@index([key])
}

// ============================================
// USER-ROLE JUNCTION - Isolated by Tenant
// ============================================
model UserRole {
  tenantId   String
  userId     String
  roleId     String
  assignedAt DateTime @default(now())

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([roleId])
}

// ============================================
// ROLE-PERMISSION JUNCTION - Isolated by Tenant
// ============================================
model RolePermission {
  tenantId     String
  roleId       String
  permissionId String
  assignedAt   DateTime @default(now())

  // Relations
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([tenantId])
  @@index([tenantId, roleId])
  @@index([permissionId])
}
