NODE_ENV=development
APP_NAME=tracker-bitacora-api
PORT=3000
API_PREFIX=api
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/bitacora
REDIS_URL=redis://localhost:6379

# JWT Configuration (REQUIRED - min 32 characters for secret)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS Configuration
# Use comma-separated values for multiple origins: http://localhost:3000,http://localhost:4200
CORS_ORIGIN=*
